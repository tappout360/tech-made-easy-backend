PORT=5000
MONGO_URI=mongodb+srv://YOUR_DB_USER:YOUR_DB_PASSWORD@cluster0.xxxxx.mongodb.net/?appName=Cluster0
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET_AT_LEAST_64_CHARS

# ── QuickBooks OAuth2 ──
# Sign up at https://developer.intuit.com → Create an app → Get keys
QB_CLIENT_ID=REPLACE_ME
QB_CLIENT_SECRET=REPLACE_ME
QB_REDIRECT_URI=http://localhost:5000/api/v1/quickbooks/callback
QB_ENVIRONMENT=sandbox

# ── Frontend URL (for OAuth redirects) ──
FRONTEND_URL=http://localhost:5173

# ── Google Maps API ──
# Get at: https://console.cloud.google.com → APIs → Credentials → API Key
# Enable: Maps JavaScript API, Geocoding API, Directions API, Distance Matrix API
GOOGLE_MAPS_KEY=REPLACE_ME

# ── Google Calendar OAuth2 ──
# Get at: https://console.cloud.google.com → APIs → Credentials → OAuth 2.0 Client
# Enable: Google Calendar API
GOOGLE_CLIENT_ID=REPLACE_ME
GOOGLE_CLIENT_SECRET=REPLACE_ME
GOOGLE_REDIRECT_URI=http://localhost:5000/api/v1/calendar/callback
