# ═══════════════════════════════════════════════════════
# Technical Made Easy — Backend Environment Variables
# ═══════════════════════════════════════════════════════
# Copy this file to `.env` and fill in values.
# ═══════════════════════════════════════════════════════

# ── Server ───────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ──────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/tme?retryWrites=true&w=majority

# ── JWT ──────────────────────────────────────────────
JWT_SECRET=your-256-bit-secret-here

# ── CORS (comma-separated frontend origins) ─────────
CORS_ORIGINS=http://localhost:5173,http://localhost:4173
FRONTEND_URL=http://localhost:5173

# ── Email (Resend) ──────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=Technical Made Easy <noreply@send.technical-made-easy.com>

# ── Stripe (payments) ───────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# ── QuickBooks ──────────────────────────────────────
QB_CLIENT_ID=
QB_CLIENT_SECRET=
QB_REDIRECT_URI=http://localhost:5000/api/v1/quickbooks/callback
QB_ENVIRONMENT=sandbox
QB_WEBHOOK_VERIFIER_TOKEN=

# ── Google Maps ─────────────────────────────────────
GOOGLE_MAPS_KEY=

# ── Epic FHIR (EHR integration) ────────────────────
EPIC_FHIR_URL=https://fhir.epic.com/interconnect-fhir-oauth/api/FHIR/R4
EPIC_CLIENT_ID=
EPIC_PRIVATE_KEY=

# ── Zoom ────────────────────────────────────────────
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
